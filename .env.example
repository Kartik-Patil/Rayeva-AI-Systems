# AI Configuration
# Groq AI (recommended free tier)
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (fallback)
# Get your Google API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-api-key-here
GEMINI_MODEL=gemini-pro-latest
GEMINI_MAX_TOKENS=1500
GEMINI_TEMPERATURE=0.7

# Database Configuration
DATABASE_URL=sqlite:///./rayeva.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rayeva

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=rayeva_dev_key_12345
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging Configuration
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
LOG_DIR=logs

# Application Settings
APP_NAME=Rayeva AI Systems
APP_VERSION=1.0.0
DEBUG=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# WhatsApp Configuration (Module 4 - Future)
WHATSAPP_API_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
